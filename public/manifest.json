{
  "manifest_version": 3,
  "name": "Refine SEO Extension",
  "version": "1.0.0",
  "description": "Website Intelligence for WordPress, WooCommerce & Modern Websites. Analyze SEO, security, performance, and tech stack — all in your browser.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "side_panel": {
    "default_path": "index.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/analyzer.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Open Refine SEO Extension",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
